---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/hero.astro";
import WorkSection from "../components/work-section.astro";
import About from "../components/about.astro";
---

<Layout
  title="Gomen's portfolio"
  description="Dev portfolio under construction"
>
  <Hero />
  <!-- Work Section (Tabs & Cards) -->
  <WorkSection />

  <!-- About / Skills Section -->
  <About />

  <!-- Contact Section -->
  <section id="contact" class="py-24 px-6 bg-stone-900 text-stone-100">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-medium mb-6">
        Let's work together.
      </h2>
      <p class="text-stone-400 mb-10 max-w-xl mx-auto">
        I'm currently available for freelance projects and open to full-time
        opportunities. If you have an idea you'd like to discuss, feel free to
        reach out.
      </p>

      <a
        href="mailto:your.email@example.com"
        class="text-2xl md:text-5xl font-serif hover:text-stone-300 transition-colors border-b border-stone-700 pb-2"
      >
        your.email@example.com
      </a>

      <div class="mt-16 flex justify-center space-x-8">
        <a
          href="#"
          class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
          >LinkedIn</a
        >
        <a
          href="#"
          class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
          >Twitter</a
        >
        <a
          href="#"
          class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
          >GitHub</a
        >
        <a
          href="#"
          class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
          >Instagram</a
        >
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer
    class="py-8 bg-stone-900 border-t border-stone-800 text-center text-stone-500 text-sm"
  >
    <p>&copy; <span id="year"></span> Juan gomen. All rights reserved.</p>
  </footer>
</Layout>

<script>
  const main = () => {
    const yearFooter = document.getElementById("year");
    if (!yearFooter) return;
    yearFooter.textContent = String(new Date().getFullYear());
  };

  main();
</script>
