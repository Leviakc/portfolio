---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/hero.astro";
import WorkSection from "@/components/work-section.astro";
import About from "@/components/about.astro";
import SocialTags from "@/components/social-tags.astro";
import { createLanguageParams } from "@/consts/constants";

export async function getStaticPaths() {
  return createLanguageParams();
}
---

<Layout
  title="Gomen's portfolio"
  description="Dev portfolio under construction"
>
  <Hero />
  <!-- Work Section (Tabs & Cards) -->
  <WorkSection />

  <!-- About / Skills Section -->
  <About />

  <!-- Contact Section -->
  <SocialTags />

  <!-- Footer -->
  <footer
    class="py-8 bg-stone-900 border-t border-stone-800 text-center text-stone-500 text-sm"
  >
    <p>&copy; <span id="year"></span> Juan gomen. All rights reserved.</p>
  </footer>
</Layout>

<script>
  const main = () => {
    const yearFooter = document.getElementById("year");
    if (!yearFooter) return;
    yearFooter.textContent = String(new Date().getFullYear());
  };

  main();
</script>
