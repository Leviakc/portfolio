---
import type { Language } from "@/types/language";
import { useTranslations } from "@/i18n/utils";

const lang = Astro.params.lang as Language;
const t = useTranslations(lang);

const socialMedias = [
  {
    name: "GitHub",
    asset: "/github.svg",
    href: "https://github.com/Leviakc",
  },
  // {
  //   name: "Instagram",
  //   asset: "/instagram.svg",
  //   href: "https://www.instagram.com/juan_gomen/",
  // },
  {
    name: "Twitter",
    asset: "/twitter.svg",
    href: "https://twitter.com/Gomen_jd",
  },
  {
    name: "LinkedIn",
    asset: "/linkedin.svg",
    href: "https://www.linkedin.com/in/juangomen/",
  },
];
---

<section id="contact" class="py-24 px-6 bg-stone-900 text-stone-100">
  <div class="max-w-5xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-serif font-medium mb-6">
      {t("contact.title")}
    </h2>
    <p class="text-stone-400 mb-10 max-w-xl mx-auto">
      {t("contact.description")}
    </p>

    <a
      href={`mailto:${t("contact.email")}`}
      class="text-2xl md:text-5xl font-serif hover:text-stone-300 transition-colors border-b border-stone-700 pb-2"
    >
      {t("contact.email")}
    </a>

    <div>
      <ul class="mt-16 flex space-x-8 justify-center">
        {
          socialMedias.map((socialMedia) => (
            <li>
              <a
                href={socialMedia.href}
                class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
                target="_blank"
                rel="noopener noreferrer"
              >
                {socialMedia.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
