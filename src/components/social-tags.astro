---
import type { Language } from "@/types/language";
import { useTranslations } from "@/i18n/utils";

const lang = Astro.params.lang as Language;
const t = useTranslations(lang);

const socialMedias = [
  {
    name: "GitHub",
    href: "https://github.com/Leviakc",
  },
  // {
  //   name: "Instagram",
  //   href: "https://www.instagram.com/juan_gomen/",
  // },
  // {
  //   name: "Twitter",
  //   href: "https://twitter.com/Gomen_jd",
  // },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/juangomen/",
  },
];

// Swap this URL when the Rust backend is ready
const CONTACT_ENDPOINT = "https://api.web3forms.com/submit";
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<section id="contact" class="py-24 px-6 bg-stone-900 text-stone-100">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-start">
      <!-- Left: info -->
      <div>
        <h2 class="text-3xl md:text-4xl font-serif font-medium mb-6">
          {t("contact.title")}
        </h2>
        <p class="text-stone-400 mb-10 leading-relaxed">
          {t("contact.description")}
        </p>
        <ul class="mt-2 flex space-x-8">
          {
            socialMedias.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="text-stone-400 hover:text-white transition-colors text-sm uppercase tracking-widest"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {s.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Right: form -->
      <div>
        <contact-form
          data-endpoint={CONTACT_ENDPOINT}
          data-success={t("contact.form.success") as string}
          data-error={t("contact.form.error") as string}
          data-sending={t("contact.form.sending") as string}
          data-submit={t("contact.form.submit") as string}
        >
          <form novalidate>
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />

            <div class="space-y-8">
              <input
                type="text"
                name="name"
                required
                placeholder={t("contact.form.name") as string}
                class="w-full bg-transparent border-b border-stone-700 text-stone-100 placeholder-stone-500 py-3 focus:border-stone-300 focus:outline-none transition-colors"
              />
              <input
                type="email"
                name="email"
                required
                placeholder={t("contact.form.email") as string}
                class="w-full bg-transparent border-b border-stone-700 text-stone-100 placeholder-stone-500 py-3 focus:border-stone-300 focus:outline-none transition-colors"
              />
              <textarea
                name="message"
                required
                rows="4"
                placeholder={t("contact.form.message") as string}
                class="w-full bg-transparent border-b border-stone-700 text-stone-100 placeholder-stone-500 py-3 focus:border-stone-300 focus:outline-none transition-colors resize-none"
              ></textarea>
            </div>

            <div class="mt-10 flex items-center gap-6">
              <button
                type="submit"
                class="contact-submit text-sm font-medium text-stone-100 border-b border-stone-500 pb-0.5 hover:text-stone-300 hover:border-stone-300 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
              >
                {t("contact.form.submit") as string} →
              </button>
              <p class="contact-status text-sm hidden"></p>
            </div>
          </form>
        </contact-form>
      </div>
    </div>
  </div>
</section>

<script>
  class ContactForm extends HTMLElement {
    connectedCallback() {
      const endpoint = this.dataset.endpoint!;
      const successMsg = this.dataset.success!;
      const errorMsg = this.dataset.error!;
      const sendingMsg = this.dataset.sending!;
      const submitMsg = this.dataset.submit!;

      const form = this.querySelector("form");
      const btn = this.querySelector<HTMLButtonElement>(".contact-submit");
      const status = this.querySelector<HTMLElement>(".contact-status");

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        btn!.disabled = true;
        btn!.textContent = sendingMsg;
        status!.classList.add("hidden");

        const data = Object.fromEntries(new FormData(form));

        try {
          const res = await fetch(endpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Accept: "application/json",
            },
            body: JSON.stringify(data),
          });

          if (res.ok) {
            form.reset();
            status!.textContent = successMsg;
            status!.className = "text-sm text-stone-300";
            status!.classList.remove("hidden");
          } else {
            throw new Error();
          }
        } catch {
          status!.textContent = errorMsg;
          status!.className = "text-sm text-red-400";
          status!.classList.remove("hidden");
        } finally {
          btn!.disabled = false;
          btn!.textContent = `${submitMsg} →`;
        }
      });
    }
  }

  customElements.define("contact-form", ContactForm);
</script>
