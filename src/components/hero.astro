---
import Nav from "./nav.astro";
import type { Language } from "@/types/language";
import { useTranslations } from "@/i18n/utils";

const lang = Astro.params.lang as Language;
const t = useTranslations(lang);
---

<Nav />
<main>
  <section class="min-h-screen flex flex-col justify-center px-6 pt-20">
    <div class="max-w-5xl mx-auto w-full">
      <div class="max-w-3xl">
        <p class="text-stone-500 font-medium mb-4 fade-in-up">
          {t("hero.greeting")}
        </p>
        <h1
          class="text-5xl md:text-7xl font-serif font-medium leading-tight mb-8 fade-in-up delay-100 text-stone-900"
        >
          {t("hero.headline")}
          <span class="italic text-stone-600"
            >{t("hero.headlineHighlight")}</span
          >
          {t("hero.headlineEnd")}
        </h1>
        <p
          class="text-xl text-stone-600 mb-10 max-w-xl leading-relaxed fade-in-up delay-200"
        >
          {t("hero.description")}
        </p>
        <div class="fade-in-up delay-300">
          <a
            href="#contact"
            class="inline-flex items-center space-x-2 text-stone-900 font-medium border-b border-stone-900 pb-1 hover:text-stone-600 hover:border-stone-600 transition-all"
          >
            <span>{t("hero.cta")}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 transform group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</main>
