---
import { LANGUAGE_METADATA, type SupportedLanguage } from "@/consts/constants";
import type { Language } from "@/types/language";
import { useTranslations } from "@/i18n/utils";

const languages = Object.entries(LANGUAGE_METADATA).map(([code, meta]) => ({
  code: code as SupportedLanguage,
  ...meta,
}));
const currentLang = Astro.params.lang as Language;
const t = useTranslations(currentLang);
---

<nav
  class="fixed w-full z-50 bg-stone-50/80 backdrop-blur-md border-b border-stone-100 transition-all duration-300"
  id="navbar"
>
  <div class="max-w-5xl mx-auto px-6 h-20 flex items-center justify-between">
    <a
      href="#"
      class="text-xl font-serif font-semibold tracking-tight hover:opacity-70 transition-opacity"
    >
      Juan Gomen
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex space-x-8 text-sm font-medium text-stone-600">
      <div class="flex space-x-8">
        <a href="#work" class="hover:text-stone-900 transition-colors">{t("nav.work")}</a>
        <a href="#about" class="hover:text-stone-900 transition-colors">{t("nav.about")}</a
        >
        <a href="#contact" class="hover:text-stone-900 transition-colors"
          >{t("nav.contact")}</a
        >
      </div>

      <!-- Language Dropdown (Desktop) -->
      <!-- Use 'relative' to position the dropdown absolute to this container -->
      <div
        class="relative pl-8 border-l border-stone-200"
        id="lang-dropdown-container"
      >
        <button
          id="lang-dropdown-button"
          class="flex items-center space-x-1 text-stone-500 hover:text-stone-900 transition-colors focus:outline-none hover:cursor-pointer"
          aria-label="Select language"
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="lang-menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <span class="uppercase font-semibold"
            >{currentLang.toUpperCase()}</span
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3 w-3"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div
          id="lang-menu"
          role="menu"
          aria-labelledby="lang-dropdown-button"
          class="hidden absolute right-0 top-full mt-3 w-32 bg-white rounded-lg shadow-xl border border-stone-100 py-1 z-50 transform origin-top-right transition-all h-fit"
        >
          {
            languages.map((lang) => (
              <button
                data-lang={lang.code}
                role="menuitem"
                aria-current={currentLang === lang.code ? "true" : "false"}
                tabindex="-1"
                class:list={[
                  {
                    "block px-4 py-2 text-sm text-stone-900 bg-stone-50 font-medium":
                      currentLang === lang.code,
                  },
                  {
                    "block px-4 py-2 text-sm text-stone-600 hover:text-stone-900 transition-colors":
                      currentLang !== lang.code,
                  },
                  "cursor-pointer w-full hover:bg-stone-200 ",
                ]}
              >
                {lang.nativeName}
              </button>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button
      class="md:hidden p-2 text-stone-600 hover:text-stone-900"
      data-menu="button"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute top-20 left-0 w-full bg-stone-50 border-b border-stone-100 p-6 flex-col space-y-4 shadow-lg"
  >
    <a href="#work" class="block text-lg font-medium text-stone-600">{t("nav.work")}</a>
    <a href="#about" class="block text-lg font-medium text-stone-600">{t("nav.about")}</a>
    <a href="#contact" class="block text-lg font-medium text-stone-600"
      >{t("nav.contact")}</a
    >

    <div class="pt-4" data-language="mobile">
      <span
        class="text-xs font-bold uppercase tracking-widest text-stone-400 block mb-3 hover:cursor-pointer"
        >{t("nav.selectLanguage")}</span
      >
      <div class="grid grid-cols-2 gap-3">
        {
          languages.map((lang) => (
            <button
              data-lang={lang.code}
              aria-current={currentLang === lang.code ? "true" : "false"}
              aria-label={`Switch to ${lang.nativeName}`}
              class:list={[
                {
                  "flex items-center justify-center py-2 px-3 bg-stone-900 text-white rounded-md text-sm font-medium shadow-sm":
                    currentLang === lang.code,
                },
                {
                  "flex items-center justify-center py-2 px-3 bg-white border border-stone-200 text-stone-600 rounded-md text-sm font-medium hover:bg-stone-100 transition-colors":
                    currentLang !== lang.code,
                },
                "cursor-pointer",
              ]}
            >
              {lang.nativeName}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</nav>
<script>
  import { navigate } from "astro:transitions/client";

  document.addEventListener("astro:page-load", () => {
    // Cache DOM elements ⬅️ STEP 3: Query elements once instead of repeatedly
    const $navbar = document.getElementById("navbar");
    const $mobileMenu = document.getElementById("mobile-menu");
    const $mobileMenuButton = document.querySelector('[data-menu="button"]') as HTMLButtonElement;
    const $langMenu = document.getElementById("lang-menu");
    const $langDropdownButton = document.getElementById("lang-dropdown-button") as HTMLButtonElement;
    const $langDropdownContainer = document.getElementById("lang-dropdown-container");
    const $desktopLangButtons = $langMenu?.querySelectorAll('[role="menuitem"]') as NodeListOf<HTMLButtonElement>;
    const $mobileLangButtons = document.querySelectorAll('[data-language="mobile"] button') as NodeListOf<HTMLButtonElement>;

    if (!$navbar || !$mobileMenu || !$mobileMenuButton) {
      console.error("Required navbar elements not found"); // ⬅️ STEP 3: Better error handling
      return;
    }

    // --- Mobile Menu Logic ---
    const toggleMobileMenu = () => {
      const isHidden = $mobileMenu.classList.contains("hidden");
      $mobileMenu.classList.toggle("hidden");
      $mobileMenu.classList.toggle("flex");
      $mobileMenuButton.setAttribute("aria-expanded", String(isHidden));
      
      // Focus management ⬅️ STEP 2: Return focus when closing
      if (!isHidden) {
        $mobileMenuButton.focus();
      }
    };

    // --- Language Dropdown Logic ---
    const toggleLangDropdown = () => {
      if (!$langMenu || !$langDropdownButton) return;
      
      const isHidden = $langMenu.classList.contains("hidden");
      $langMenu.classList.toggle("hidden");
      $langDropdownButton.setAttribute("aria-expanded", String(isHidden));
      
      // Focus first menu item when opening ⬅️ STEP 2: Keyboard focus management
      if (isHidden && $desktopLangButtons.length > 0) {
        $desktopLangButtons[0].focus();
        $desktopLangButtons[0].tabIndex = 0;
      }
    };

    const closeLangDropdown = () => {
      if (!$langMenu || !$langDropdownButton) return;
      
      if (!$langMenu.classList.contains("hidden")) {
        $langMenu.classList.add("hidden");
        $langDropdownButton.setAttribute("aria-expanded", "false");
        $langDropdownButton.focus(); // ⬅️ STEP 2: Return focus to button
      }
    };

    // --- Language Change Logic ---
    const changeLanguage = (element: HTMLElement | null) => {
      if (!element) return;
      
      const selectedLang = element.getAttribute("data-lang");
      const currentPath = window.location.pathname;
      
      if (!selectedLang) return;
      if (currentPath.includes(`/${selectedLang}/`)) return;

      const newPath = window.location.href.replace(
        currentPath,
        `/${selectedLang}/`,
      );
      navigate(newPath);
    };

    // --- Event Handlers --- ⬅️ STEP 3: Proper event delegation
    const handleMobileMenuClick = (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-menu="button"]')) {
        toggleMobileMenu();
      }
    };

    const handleLangDropdownClick = (e: Event) => {
      const target = e.target as HTMLElement;
      
      // Toggle dropdown if clicking the button
      if (target.closest('#lang-dropdown-button')) {
        e.stopPropagation();
        toggleLangDropdown();
        return;
      }
      
      // Change language if clicking a menu item
      const langButton = target.closest('[role="menuitem"]') as HTMLElement;
      if (langButton) {
        changeLanguage(langButton);
        closeLangDropdown();
      }
    };

    const handleClickOutside = (event: Event) => {
      const target = event.target as HTMLElement;
      
      if ($langDropdownContainer && !$langDropdownContainer.contains(target)) {
        closeLangDropdown();
      }
    };

    // ⬅️ STEP 2: KEYBOARD NAVIGATION for dropdown
    const handleDropdownKeydown = (e: KeyboardEvent) => {
      if (!$langMenu || !$desktopLangButtons) return;
      
      const isOpen = !$langMenu.classList.contains("hidden");
      
      switch (e.key) {
        case "Escape": // Close dropdown with Escape key
          if (isOpen) {
            e.preventDefault();
            closeLangDropdown();
          }
          break;
          
        case "ArrowDown": // Navigate to next language option
          if (isOpen) {
            e.preventDefault();
            const currentIndex = Array.from($desktopLangButtons).findIndex(btn => btn === document.activeElement);
            const nextIndex = (currentIndex + 1) % $desktopLangButtons.length;
            $desktopLangButtons[currentIndex]?.setAttribute('tabindex', '-1');
            $desktopLangButtons[nextIndex]?.setAttribute('tabindex', '0');
            $desktopLangButtons[nextIndex]?.focus();
          }
          break;
          
        case "ArrowUp": // Navigate to previous language option
          if (isOpen) {
            e.preventDefault();
            const currentIndex = Array.from($desktopLangButtons).findIndex(btn => btn === document.activeElement);
            const prevIndex = currentIndex <= 0 ? $desktopLangButtons.length - 1 : currentIndex - 1;
            $desktopLangButtons[currentIndex]?.setAttribute('tabindex', '-1');
            $desktopLangButtons[prevIndex]?.setAttribute('tabindex', '0');
            $desktopLangButtons[prevIndex]?.focus();
          }
          break;
          
        case "Enter":
        case " ": // Select language option with Enter or Space
          if (isOpen && document.activeElement instanceof HTMLElement) {
            e.preventDefault();
            changeLanguage(document.activeElement);
            closeLangDropdown();
          }
          break;
      }
    };

    // --- Attach Event Listeners ---
    $mobileMenuButton.addEventListener("click", handleMobileMenuClick);
    $langDropdownContainer?.addEventListener("click", handleLangDropdownClick);
    document.addEventListener("click", handleClickOutside);
    $langDropdownContainer?.addEventListener("keydown", handleDropdownKeydown); // ⬅️ STEP 2: Attach keyboard handler

    // Mobile language buttons
    const mobileLangHandlers = new Map<HTMLButtonElement, () => void>();
    $mobileLangButtons.forEach(($btn) => {
      const handler = () => changeLanguage($btn);
      mobileLangHandlers.set($btn, handler);
      $btn.addEventListener("click", handler);
    });

    // ⬅️ STEP 3: CLEANUP - Remove event listeners before page transition (prevents memory leaks)
    document.addEventListener("astro:before-preparation", () => {
      $mobileMenuButton.removeEventListener("click", handleMobileMenuClick);
      $langDropdownContainer?.removeEventListener("click", handleLangDropdownClick);
      document.removeEventListener("click", handleClickOutside);
      $langDropdownContainer?.removeEventListener("keydown", handleDropdownKeydown);

      $mobileLangButtons.forEach(($btn) => {
        const handler = mobileLangHandlers.get($btn);
        if (handler) $btn.removeEventListener("click", handler);
      });
    }, { once: true });
  });
</script>
